# Clé de chiffrement n8n (obligatoire — mettre une chaîne aléatoire quelconque)
N8N_ENCRYPTION_KEY=change-me-to-a-random-string

# Note : la clé API Anthropic se configure directement dans n8n
# via http://localhost:5678/credentials → Add credential → Anthropic
# Elle n'est PAS stockée ici pour des raisons de sécurité.
